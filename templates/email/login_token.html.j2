{% extends "layout.html.j2" %}

{% block title %}Email Verification - lnkr{% endblock %}

{% block content %}
<table
  role="presentation"
  width="100%"
  cellpadding="0"
  cellspacing="0"
  border="0"
>
  <tr>
    <td style="padding-bottom: 20px">
      <h2 style="margin: 0; font-size: 24px; font-weight: 600; color: #f5e0dc">
        You're almost there!
      </h2>
    </td>
  </tr>

  <tr>
    <td
      style="
        padding-bottom: 25px;
        color: #cdd6f4;
        font-size: 16px;
        line-height: 1.6;
      "
    >
      Use the code below or click the button to securely sign in.<br />
      This token will expire in {{ expiry_time }} minutes.
    </td>
  </tr>

  <tr>
    <td style="padding-bottom: 20px; text-align: center">
      <table
        role="presentation"
        cellpadding="0"
        cellspacing="0"
        border="0"
        style="width: 80%; margin: 0 auto"
      >
        <tr>
          <td
            style="
              background-color: #313244;
              border: 1px solid #585b70;
              border-radius: 8px;
              padding: 24px 20px;
              text-align: center;
            "
          >
            <span
              class="login-token"
              style="
                font-size: 32px;
                font-weight: bold;
                letter-spacing: 18px;
                font-family: 'SF Mono', Monaco, Menlo, 'Courier New', Courier, monospace;
                color: #f5e0dc;
              "
              >{{ token }}</span
            >
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <tr>
    <td
      style="
        text-align: center;
        padding: 10px 0;
        color: #bac2de;
        font-size: 14px;
      "
    >
      OR
    </td>
  </tr>

  <tr>
    <td style="text-align: center; padding: 10px 0 30px">
      <table
        role="presentation"
        cellpadding="0"
        cellspacing="0"
        border="0"
        style="margin: 0 auto"
      >
        <tr>
          <td
            style="
              background-color: #89b4fa;
              border: 2px solid #b4befe;
              border-radius: 8px;
            "
          >
            <a
              href="{{ login_url }}"
              style="
                display: inline-block;
                padding: 14px 36px;
                color: #1e1e2e;
                text-decoration: none;
                font-size: 20px;
                font-weight: 600;
              "
              >Sign In</a
            >
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <tr>
    <td style="padding: 20px 0">
      <table
        role="presentation"
        width="100%"
        cellpadding="0"
        cellspacing="0"
        border="0"
        style="
          background-color: #313244;
          border: 1px solid #585b70;
          border-radius: 8px;
          color: #cdd6f4;
          font-size: 14px;
          line-height: 1.6;
        "
      >
        <tr>
          <td colspan="2" style="padding: 16px 20px 8px; font-size: 16px; font-weight: 600">
            Request details
          </td>
        </tr>
        <tr>
          <td style="padding: 4px 20px; color: #a6adc8">IP address</td>
          <td class="request-ip-address" style="padding: 4px 20px; text-align: right">
            {{ ip_address or "Unavailable" }}
          </td>
        </tr>
        <tr>
          <td style="padding: 4px 20px; color: #a6adc8">Country code</td>
          <td class="request-country-code" style="padding: 4px 20px; text-align: right">
            {{ country_code or "Unavailable" }}
          </td>
        </tr>
        <tr>
          <td style="padding: 4px 20px 16px; color: #a6adc8">User agent</td>
          <td class="request-user-agent" style="padding: 4px 20px 16px; text-align: right">
            {% if user_agent and user_agent.browser and user_agent.operating_system %}
              {{ user_agent.browser }} on {{ user_agent.operating_system }}
            {% elif user_agent and user_agent.browser %}
              {{ user_agent.browser }}
            {% elif user_agent and user_agent.operating_system %}
              {{ user_agent.operating_system }}
            {% else %}
              Unavailable
            {% endif %}
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <tr>
    <td
      style="
        padding-top: 20px;
        color: #a6adc8;
        font-size: 14px;
        font-style: italic;
      "
    >
      If you did not request this email, you can safely ignore it.
    </td>
  </tr>
</table>
{% endblock %}
